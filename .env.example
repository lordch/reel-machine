# ElevenLabs — text-to-speech narration + music (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HeyGen — AI avatar video generation (https://heygen.com)
HEYGEN_API_KEY=your_heygen_api_key_here

# Fal.ai — AI video generation (https://fal.ai)
FAL_KEY=your_fal_api_key_here

# Pexels — stock video search (https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# ── API Server ──
PORT=3001
API_SECRET=change-me-to-a-random-string

# ── Google Sheets ──
GOOGLE_SHEETS_ID=                    # spreadsheet ID from URL
GOOGLE_SERVICE_ACCOUNT_KEY=./google-sa-key.json

# ── Claude (scenario generation) ──
ANTHROPIC_API_KEY=
SCENARIO_MODEL=claude-haiku-4-5-20251001  # or claude-sonnet-4-6, claude-opus-4-6

# ── Cloudflare R2 (video storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=reel-machine
R2_ENDPOINT=                          # https://{ACCOUNT_ID}.r2.cloudflarestorage.com
R2_PUBLIC_URL=                        # https://pub-{ACCOUNT_ID}.r2.dev (enable public access first)

# ngrok (for local development)
NGROK_AUTHTOKEN=
